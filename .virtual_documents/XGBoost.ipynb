import xgboost as xgb
from sklearn.datasets import make_classification
from sklearn.model_selection import train_test_split
from sklearn.metrics import accuracy_score, classification_report


X, y = make_classification(
    n_samples=500, #rows
    n_features=20, #input columns feature excluding target
    n_informative=10,#features actually decide the target
    n_redundant=2,#example 1 feature is derived from informative ones (e.g., f4 may be a combination like f1 + f2).
    random_state=42
)

X_train, X_test, y_train, y_test = train_test_split(
    X, y, test_size=0.3, random_state=42 
)


xgb_clf = xgb.XGBClassifier(
    n_estimators=100,
    max_depth=3,
    learning_rate=0.1,
    eval_metric="logloss", # logloss measures how well predicted probabilities match the true class labels (lower is better)
    random_state=42
)



xgb_clf.fit(X_train, y_train)


y_pred = xgb_clf.predict(X_test)

print("accuracy: ", accuracy_score(y_test, y_pred))


print("CR: ", classification_report(y_test, y_pred)) # with a same implementation we can make XGBoosting regressor model



