# classifier

from sklearn.datasets import make_classification
from sklearn.model_selection import train_test_split
from sklearn.metrics import accuracy_score, classification_report
from sklearn.tree import DecisionTreeClassifier


X, y = make_classification(
    n_samples=500, #rows
    n_features=20, #input columns feature excluding target
    n_informative=10,#features actually decide the target
    n_redundant=2,#example 1 feature is derived from informative ones (e.g., f4 may be a combination like f1 + f2).
    random_state=42
)

X_train, X_test, y_train, y_test = train_test_split(
    X, y, test_size=0.3, random_state=42 
)


# decision tree stump means a a DT with single split

from sklearn.ensemble import AdaBoostClassifier
base_model = DecisionTreeClassifier(
    max_depth = 1
)

ada = AdaBoostClassifier(
    estimator=base_model,
    n_estimators=100,
    random_state=42
)


ada.fit(X_train, y_train)


y_pred = ada.predict(X_test)


print("accuracy: ", accuracy_score(y_test, y_pred))


print("classification Report: ", classification_report(y_test, y_pred))



